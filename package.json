{
  "name": "vellora-editor",
  "productName": "Vellora",
  "version": "2.1.0",
  "description": "Vellora lightweight Markdown viewer and editor",
  "author": "Vellora Contributors",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mirad-tech/vellora.git"
  },
  "bugs": {
    "url": "https://github.com/mirad-tech/vellora/issues"
  },
  "homepage": "https://github.com/mirad-tech/vellora#readme",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite",
    "build": "npm run typecheck && npm run build:web && tauri build --bundles nsis",
    "build:web": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:e2e": "node tests/e2e/smoke.mjs",
    "test:e2e:ci": "node tests/e2e/smoke.mjs",
    "test:e2e:desktop": "node tests/e2e/run-desktop.mjs",
    "tools:msedgedriver": "node tools/fetch-msedgedriver.mjs",
    "tauri": "tauri",
    "dist": "npm run build",
    "generate:icon": "node build/generate-icon.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "dompurify": "^3.4.9",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@testing-library/react": "^16.3.0",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.0",
    "@wdio/cli": "^9.12.0",
    "@wdio/local-runner": "^9.12.0",
    "@wdio/mocha-framework": "^9.12.0",
    "@wdio/spec-reporter": "^9.12.0",
    "jsdom": "^29.1.1",
    "puppeteer-core": "^24.43.1",
    "typescript": "^5.9.2",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  }
}
